{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": ["**", "!static", "!bun.lock", "!build", "!.svelte-kit"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineEnding": "crlf",
		"lineWidth": 100
	},
	"assist": {
		"enabled": true,
		"actions": {
			"recommended": false,
			"source": {
				"organizeImports": {
					"level": "on",
					"options": {
						"groups": [
							{
								"source": [":PACKAGE:", "!svelte", "!svelte/*", "!@sveltejs/*"]
							},
							":BLANK_LINE:",
							{
								"source": ["svelte", "svelte/*", "@sveltejs/*"]
							},
							":BLANK_LINE:",
							["$*", "$*/**"],
							":BLANK_LINE:",
							["./*", "../*", "./**", "../**"]
						]
					}
				}
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"trailingCommas": "none"
		}
	},
	"json": {
		"formatter": {
			"trailingCommas": "none"
		}
	},
	"overrides": [
		{
			"includes": ["**/*.svelte"],
			"linter": {
				"rules": {
					"correctness": {
						"noUnusedImports": "off",
						"noUnusedVariables": "off"
					},
					"style": {
						"useImportType": "off"
					}
				}
			}
		}
	]
}
